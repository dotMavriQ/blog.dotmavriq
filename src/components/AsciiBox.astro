---
/*
  AsciiBox.astro
  Frames content with box-drawing characters.
*/
interface Props {
  title?: string;
  class?: string;
}

const { title, class: className } = Astro.props;
---

<div class={`ascii-box ${className || ""}`}>
  <div class="box-top" aria-hidden="true">
    <span class="cor-tl">┌</span>
    <div class="box-hr">
      {title && <span class="box-title"> {title} </span>}
    </div>
    <span class="cor-tr">┐</span>
  </div>
  <div class="box-content">
    <div class="box-vr-l" aria-hidden="true">│</div>
    <div class="box-inner">
      <slot />
    </div>
    <div class="box-vr-r" aria-hidden="true">│</div>
  </div>
  <div class="box-bottom" aria-hidden="true">
    <span class="cor-bl">└</span>
    <div class="box-hr"></div>
    <span class="cor-br">┘</span>
  </div>
</div>

<style>
  .ascii-box {
    display: flex;
    flex-direction: column;
    font-family: var(--font-mono);
    margin: 1rem 0;
  }

  .box-top,
  .box-bottom {
    display: flex;
    align-items: center;
    line-height: 1;
    color: var(--cloud);
  }

  .box-hr {
    flex: 1;
    border-top: 1px solid var(--cloud);
    display: flex;
    align-items: center;
    position: relative;
    height: 0;
    margin: 0 -1px; /* Overlap with corners */
  }

  /* Replace 1px solid with characters if we want pure ASCII,
     but 1px solid ensures perfect alignment on high-DPI */
  .box-hr::after {
    content: "";
    display: block;
    width: 100%;
    /* We use border for alignment, but could use repeating characters */
  }

  .box-title {
    background: var(--bg);
    padding: 0 0.5rem;
    font-size: 0.75rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    position: absolute;
    left: 1rem;
    top: -0.5rem;
  }

  .box-content {
    display: flex;
    min-height: 1rem;
  }

  .box-vr-l,
  .box-vr-r {
    color: var(--cloud);
    border-left: 1px solid var(--cloud);
    width: 0;
    line-height: 1;
    display: flex;
    align-items: stretch;
    overflow: hidden;
    text-indent: -9999px; /* Hide character, use border for precision */
  }

  .box-inner {
    flex: 1;
    padding: 1rem 1.5rem;
  }

  .cor-tl,
  .cor-tr,
  .cor-bl,
  .cor-br {
    font-size: 1.2rem;
    line-height: 0.8;
  }
</style>
