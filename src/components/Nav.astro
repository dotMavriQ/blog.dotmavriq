---
const navItems = [
  { href: "/cv", label: "cv" },
  { href: "/portfolio", label: "portfolio" },
  { href: "/about", label: "about" },
  { href: "/blog", label: "blog" },
  { href: "/contact", label: "contact" },
];
---

<nav class="nav" aria-label="Site navigation" transition:animate="none">
  <div class="nav-bar container">
    <a class="nav-logo" href="/"><span class="slash">//</span> blog.dotmavriq.life</a>
    <div class="nav-right">
      <ul class="nav-links" id="nav-links" role="list">
        {navItems.map(({ href, label }) => <li><a href={href}>{label}</a></li>)}
      </ul>
      <button
        class="theme-toggle"
        id="theme-toggle"
        aria-label="Toggle colour theme"
      >
        <span class="icon-sun" aria-hidden="true">☼</span>
        <span class="icon-moon" aria-hidden="true">☽</span>
      </button>
      <button
        class="nav-toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        id="nav-toggle"
        aria-label="Toggle menu"
      >
        ☰
      </button>
    </div>
  </div>

  <!-- Kinetic Cloud Border -->
  <slot name="marquee" />
</nav>

<!-- Mobile menu overlay — sibling of nav and page-scroll, no stacking context issues -->
<div id="mobile-menu" class="mobile-menu" role="dialog" aria-label="Navigation" hidden>
  <ul class="mobile-menu__links" role="list">
    {navItems.map(({ href, label }) => <li><a href={href}>{label}</a></li>)}
  </ul>
</div>

<script>
  import { toggleTheme } from "../scripts/theme";

  let ac: AbortController | null = null;

  const init = () => {
    ac?.abort();
    ac = new AbortController();
    const { signal } = ac;

    const themeToggle = document.getElementById("theme-toggle");
    if (themeToggle) {
      themeToggle.addEventListener("click", () => toggleTheme(), { signal });
    }

    const navToggle = document.getElementById("nav-toggle");
    const mobileMenu = document.getElementById("mobile-menu");

    if (navToggle && mobileMenu) {
      navToggle.addEventListener("click", () => {
        const open = mobileMenu.toggleAttribute("hidden");
        navToggle.setAttribute("aria-expanded", String(!open));
      }, { signal });

      mobileMenu.querySelectorAll("a").forEach(link => {
        link.addEventListener("click", () => {
          mobileMenu.toggleAttribute("hidden", true);
          navToggle.setAttribute("aria-expanded", "false");
        }, { signal });
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !mobileMenu.hasAttribute("hidden")) {
          mobileMenu.toggleAttribute("hidden", true);
          navToggle.setAttribute("aria-expanded", "false");
        }
      }, { signal });
    }

    // Measure nav height for hero viewport fill
    const navEl = document.querySelector(".nav") as HTMLElement;
    if (navEl) {
      const setNavHeight = () => {
        document.documentElement.style.setProperty(
          "--nav-total-height",
          navEl.offsetHeight + "px"
        );
      };
      setNavHeight();
      new ResizeObserver(setNavHeight).observe(navEl);
    }
  };

  document.addEventListener("astro:page-load", init);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init, { once: true });
  } else {
    init();
  }
</script>

<style>
  :root {
    --nav-total-height: 110px; /* Fallback for CLS reduction */
  }

  .nav {
    width: 100%;
    background: var(--bg);
    transition: background 0.3s;
    z-index: var(--z-nav);
    border-bottom: 1px solid var(--cloud);
  }
  .nav-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 20px;
    gap: 1rem;
    max-width: 1200px;
  }
  .nav-logo {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .nav-logo .slash {
    color: var(--muted);
    font-weight: 400;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .nav-links {
    display: flex;
    gap: 1.25rem;
    list-style: none;
  }
  .nav-links a {
    color: var(--muted);
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .nav-links a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .theme-toggle {
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    padding: 0;
    font-size: 1.1rem;
    transition: color 0.1s;
    width: 1.5rem;
    height: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }
  .theme-toggle:hover {
    color: var(--accent);
  }

  .nav-toggle {
    display: none;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 1.2rem;
  }

  @media (max-width: 600px) {
    .nav-toggle {
      display: block;
      position: relative;
      z-index: var(--z-chrome-top);
    }

    .nav-links {
      display: none;
    }

    .nav {
      position: relative;
      z-index: var(--z-mobile-nav);
    }
  }

  .mobile-menu {
    display: none;
  }
  .mobile-menu:not([hidden]) {
    display: flex;
    position: fixed;
    inset: 0;
    z-index: var(--z-mobile-overlay);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    background: #f5f3ec;
    margin: 0;
  }
  :global([data-theme="dark"]) .mobile-menu:not([hidden]) {
    background: #1a1a17;
  }
  .mobile-menu__links {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    padding: 0;
    margin: 0;
  }
  .mobile-menu__links a {
    color: var(--muted);
    font-size: 1.2rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
  }
  .mobile-menu__links a:hover {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
