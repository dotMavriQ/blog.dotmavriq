<script>
  function initPortfolio() {
    const link = document.querySelector('.meta-live-link');
    if (link) {
      // Reset state in case we're returning via View Transition
      (link as HTMLElement).style.opacity = '';
      (link as HTMLElement).style.display = '';
      link.textContent = 'Live\u00a0→';
    }
    link?.addEventListener('click', (e) => {
      e.preventDefault();
      const l = e.currentTarget as HTMLAnchorElement;
      l.textContent = "don't be silly...";
      l.style.transition = 'opacity 1.2s';
      l.style.opacity = '0';
      setTimeout(() => { l.style.display = 'none'; }, 1200);
    });
  }

  document.addEventListener("astro:page-load", initPortfolio);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initPortfolio, { once: true });
  } else {
    initPortfolio();
  }
</script>
