---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CloudMarquee from "../../components/CloudMarquee.astro";
import { getCollection, render } from "astro:content";
import { Image, Picture } from "astro:assets";
import { getBlogHeroImage } from "../../lib/blog-hero-images";
import { AUTHOR, SITE } from "../../lib/author";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((post) => !post.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Prev/next: inside a series, follow part order (I → II → III).
// Outside a series, fall back to reverse-chron across non-series posts.
const allPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

let prevPost: (typeof allPosts)[number] | null = null;
let nextPost: (typeof allPosts)[number] | null = null;

if (post.data.series) {
  const siblings = allPosts
    .filter((p) => p.data.series === post.data.series)
    .sort((a, b) => (a.data.part ?? 0) - (b.data.part ?? 0));
  const idx = siblings.findIndex((p) => p.id === post.id);
  prevPost = idx > 0 ? siblings[idx - 1] : null;
  nextPost = idx < siblings.length - 1 ? siblings[idx + 1] : null;
} else {
  const standalone = allPosts.filter((p) => !p.data.series);
  const idx = standalone.findIndex((p) => p.id === post.id);
  prevPost = idx < standalone.length - 1 ? standalone[idx + 1] : null;
  nextPost = idx > 0 ? standalone[idx - 1] : null;
}

// Reading time
const wordCount = post.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

// Filter to h2/h3/h4 for ToC (exclude the sr-only footnote label).
// Convention: a trailing "(…)" in a heading is treated as supplementary
// context (dates, subtitles) and stripped from the ToC label so sidebar
// entries stay short. The in-body heading still renders with the parens.
const stripTrailingParens = (text: string) => text.replace(/\s*\([^()]*\)\s*$/, '').trim();
const tocHeadings = headings
  .filter((h) => (h.depth === 2 || h.depth === 3 || h.depth === 4) && h.slug !== 'footnote-label')
  .map((h) => ({ ...h, text: stripTrailingParens(h.text) }));

// Build a nested tree grouping h3/h4 under their nearest preceding h2 so
// the ToC can progressively disclose sub-headings only when the parent is
// active (scrolled into view) or hovered.
type TocNode = { depth: number; slug: string; text: string; children: TocNode[] };
const tocTree: TocNode[] = [];
let tocCurrentGroup: TocNode | null = null;
for (const h of tocHeadings) {
  if (h.depth === 2) {
    tocCurrentGroup = { ...h, children: [] };
    tocTree.push(tocCurrentGroup);
  } else if (tocCurrentGroup) {
    tocCurrentGroup.children.push({ ...h, children: [] });
  } else {
    tocTree.push({ ...h, children: [] });
  }
}
const tocTotalEntries = tocTree.reduce((n, g) => n + 1 + g.children.length, 0);

const siteUrl = SITE.url;
const postUrl = `${siteUrl}/blog/${post.id}/`;
const postDescription = post.data.excerpt || `Blog post: ${post.data.title}`;
const prevUrl = prevPost ? `${siteUrl}/blog/${prevPost.id}/` : null;
const nextUrl = nextPost ? `${siteUrl}/blog/${nextPost.id}/` : null;
const heroImage = getBlogHeroImage(post.data.heroImage);
const heroImageUrl = post.data.heroImage ? `${siteUrl}${post.data.heroImage}` : undefined;

const seriesJsonLd = post.data.series
  ? {
      isPartOf: {
        "@type": "CreativeWorkSeries",
        name: post.data.seriesTitle || post.data.series,
        numberOfItems: post.data.partsTotal,
      },
      position: post.data.part,
    }
  : {};

const authorJsonLd = {
  "@type": "Person",
  name: AUTHOR.name,
  alternateName: AUTHOR.alternateName,
  url: AUTHOR.url,
  sameAs: AUTHOR.sameAs,
};

const blogPostingJsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: postDescription,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  url: postUrl,
  author: authorJsonLd,
  publisher: authorJsonLd,
  ...(heroImageUrl && { image: heroImageUrl }),
  mainEntityOfPage: { "@type": "WebPage", "@id": postUrl },
  wordCount: wordCount,
  inLanguage: SITE.language,
  ...seriesJsonLd,
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Blog", item: `${siteUrl}/blog/` },
    { "@type": "ListItem", position: 3, name: post.data.title, item: postUrl },
  ],
};

const jsonLd = JSON.stringify(blogPostingJsonLd);
const breadcrumbLd = JSON.stringify(breadcrumbJsonLd);
---

<BaseLayout
  title={`${post.data.title} // dotmavriq`}
  description={postDescription}
  ogType="article"
  ogImage={heroImageUrl}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={jsonLd} />
    <script is:inline type="application/ld+json" set:html={breadcrumbLd} />
    {prevUrl && <link rel="prev" href={prevUrl} />}
    {nextUrl && <link rel="next" href={nextUrl} />}
  </Fragment>
  <CloudMarquee slot="marquee" />
  <div class="reading-progress" aria-hidden="true"><div class="reading-progress-fill" id="reading-progress"></div></div>
  <article class="post-article">
    <!-- Post header -->
    <header class={`post-header neu-border-bottom ${post.data.heroImage ? "has-illus" : ""}`}>
      {(heroImage || post.data.heroImage) && (
        <div class="post-illus">
          {heroImage ? (
            heroImage.isSvg ? (
              <Image
                src={heroImage.asset}
                alt={`Illustration for ${post.data.title}`}
                loading="eager"
                decoding="async"
              />
            ) : (
              <Picture
                src={heroImage.asset}
                alt={`Illustration for ${post.data.title}`}
                formats={["avif", "webp"]}
                fallbackFormat={heroImage.fallbackFormat}
                widths={[220, 320, 640]}
                sizes="(min-width: 900px) min(26vw, 320px), min(25vw, 320px)"
                loading="eager"
                decoding="async"
              />
            )
          ) : (
            <img
              src={post.data.heroImage}
              alt={`Illustration for ${post.data.title}`}
              width="320"
              height="240"
              loading="eager"
              decoding="async"
            />
          )}
        </div>
      )}
      <h1 class="post-title-main prefix-slash">{post.data.title}</h1>
      <div class="post-meta">
        <time datetime={post.data.pubDate.toISOString()}>{new Intl.DateTimeFormat("en-GB", { day: "numeric", month: "short", year: "numeric" }).format(post.data.pubDate)}</time>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span>{readingTime} min read</span>
        {post.data.tags.length > 0 && (
          <>
            <span class="meta-sep" aria-hidden="true">·</span>
            <div class="post-tags">
              {post.data.tags.map((tag) => (
                <a href={`/blog/?tags=${encodeURIComponent(tag)}`} class="tag-link">{tag}</a>
              ))}
            </div>
          </>
        )}
      </div>
    </header>

    <!-- Mobile ToC -->
    {tocTotalEntries > 1 && (
      <details class="mobile-toc neu-box-sm">
        <summary class="toc-summary">Table of Contents</summary>
        <nav class="toc-nav" aria-label="Table of contents">
          <ul>
            {tocTree.map((group) => (
              <li class="toc-group">
                <a href={`#${group.slug}`} class="toc-link" data-heading={group.slug}>{group.text}</a>
                {group.children.length > 0 && (
                  <ul class="toc-children">
                    {group.children.map((child) => (
                      <li class={child.depth === 4 ? "toc-h4" : "toc-h3"}>
                        <a href={`#${child.slug}`} class="toc-link" data-heading={child.slug}>{child.text}</a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </nav>
      </details>
    )}

    <!-- Post body -->
    <div class="post-content">
      <Content />
    </div>

    <!-- Post navigation -->
    <nav class="post-nav neu-border-top" aria-label={post.data.series ? "Series navigation" : "Post navigation"}>
      {prevPost ? (
        <a href={`/blog/${prevPost.id}/`} class="nav-prev" rel="prev">
          <span class="nav-label">{post.data.series ? `← part ${prevPost.data.part ?? ""}` : "← prev"}</span>
          <span class="nav-title">{prevPost.data.title}</span>
        </a>
      ) : <div />}
      {nextPost ? (
        <a href={`/blog/${nextPost.id}/`} class="nav-next" rel="next">
          <span class="nav-label">{post.data.series ? `part ${nextPost.data.part ?? ""} →` : "next →"}</span>
          <span class="nav-title">{nextPost.data.title}</span>
        </a>
      ) : <div />}
    </nav>

    <a href="/blog/" class="back-to-blog">← back to blog</a>

    <!-- Desktop ToC sidebar -->
    {tocTotalEntries > 1 && (
      <aside class="toc-sidebar neu-border-left-sm" id="toc-sidebar">
        <h2 class="toc-heading sr-only">Contents</h2>
        <span class="toc-scroll-hint toc-scroll-hint-top" aria-hidden="true">▴</span>
        <ul class="toc-list" data-scroll="none">
          {tocTree.map((group) => (
            <li class="toc-group">
              <a href={`#${group.slug}`} class="toc-link" data-heading={group.slug}>
                {group.text}
              </a>
              {group.children.length > 0 && (
                <ul class="toc-children">
                  {group.children.map((child) => (
                    <li class={child.depth === 4 ? "toc-h4" : "toc-h3"}>
                      <a href={`#${child.slug}`} class="toc-link" data-heading={child.slug}>
                        {child.text}
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
        <span class="toc-scroll-hint toc-scroll-hint-bottom" aria-hidden="true">▾</span>
      </aside>
    )}
  </article>
</BaseLayout>

<script>
  let blogPostAc: AbortController | null = null;

  function initBlogPost() {
    blogPostAc?.abort();
    blogPostAc = new AbortController();
    const { signal } = blogPostAc;

    // Scroll-spy for desktop ToC
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (tocLinks.length) {
      const headingEls = Array.from(tocLinks).map((link) =>
        document.getElementById(link.dataset.heading || '')
      ).filter(Boolean) as HTMLElement[];

      let currentId = '';

      const allGroups = document.querySelectorAll<HTMLElement>('.toc-group');

      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              currentId = entry.target.id;
              break;
            }
          }
          tocLinks.forEach((link) => {
            link.classList.toggle('toc-active', link.dataset.heading === currentId);
          });
          // Expand only the group containing the active link; collapse others.
          const activeGroups = new Set<Element>();
          document.querySelectorAll('.toc-link.toc-active').forEach((link) => {
            const group = link.closest('.toc-group');
            if (group) activeGroups.add(group);
          });
          allGroups.forEach((g) => {
            g.classList.toggle('expanded', activeGroups.has(g));
          });
        },
        { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
      );

      headingEls.forEach((el) => observer.observe(el));
    }

    // ToC scroll-state indicator (top/middle/bottom/none) — drives fade masks
    // and chevron affordances so users know the list is scrollable.
    const tocList = document.querySelector<HTMLElement>('.toc-list');
    if (tocList) {
      const updateTocScrollState = () => {
        const { scrollTop, scrollHeight, clientHeight } = tocList;
        const overflow = scrollHeight - clientHeight;
        if (overflow <= 1) {
          tocList.dataset.scroll = 'none';
          return;
        }
        const atTop = scrollTop <= 2;
        const atBottom = scrollTop >= overflow - 2;
        tocList.dataset.scroll = atTop ? 'top' : atBottom ? 'bottom' : 'middle';
      };
      tocList.addEventListener('scroll', updateTocScrollState, { passive: true, signal });
      window.addEventListener('resize', updateTocScrollState, { passive: true, signal });
      updateTocScrollState();
    }

    // Reading progress bar
    const progressBar = document.getElementById('reading-progress');
    if (progressBar) {
      const article = document.querySelector('.post-article');
      let ticking = false;

      const updateProgress = () => {
        if (!article) return;
        const articleTop = (article as HTMLElement).offsetTop;
        const articleHeight = (article as HTMLElement).offsetHeight;
        const windowHeight = window.innerHeight;
        const scrolled = window.scrollY - articleTop;
        const total = articleHeight - windowHeight;
        const progress = Math.min(Math.max(scrolled / total, 0), 1);
        progressBar.style.transform = `scaleX(${progress})`;
        ticking = false;
      };

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(updateProgress);
          ticking = true;
        }
      }, { passive: true, signal });

      updateProgress();
    }

    // External links inside the post body → new tab (skips footnote anchors, which start with "#")
    document.querySelectorAll<HTMLAnchorElement>('.post-content a[href^="http"]').forEach((a) => {
      try {
        if (new URL(a.href).origin === location.origin) return;
      } catch { return; }
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
    });

    // Smooth scroll for ToC clicks
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const id = a.getAttribute('href')?.slice(1);
        if (!id) return;
        const target = document.getElementById(id);
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        history.replaceState(null, '', `#${id}`);
      }, { signal });
    });
  }

  document.addEventListener("astro:page-load", initBlogPost);
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBlogPost, { once: true });
  } else {
    initBlogPost();
  }
</script>

<style>
  /* ── Reading progress bar ── */
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    z-index: 9999;
    background: transparent;
    pointer-events: none;
  }

  .reading-progress-fill {
    height: 100%;
    background: var(--accent);
    transform-origin: left;
    transform: scaleX(0);
    will-change: transform;
  }

  /* ── Widen blog container to match nav (1200px) ── */
  :global(.page-content.container) {
    max-width: 1200px;
  }

  .post-article {
    padding: clamp(2rem, 4vw, 3rem) 0 5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .post-illus {
    float: right;
    width: clamp(200px, 25vw, 320px);
    max-height: 280px;
    margin: 0 0 1rem 1.5rem;
    mix-blend-mode: multiply;
    filter: contrast(1.1);
    opacity: 0.85;
  }

  .post-illus :global(picture),
  .post-illus :global(img) {
    display: block;
    width: 100%;
    height: auto;
    max-height: 280px;
    object-fit: contain;
  }

  :global([data-theme="dark"]) .post-illus {
    mix-blend-mode: screen;
    filter: invert(1) contrast(1.1);
    opacity: 0.9;
  }

  .post-header {
    margin-bottom: 1.7rem;
    padding: 0 0 1.4rem;
  }

  .post-title-main {
    font-size: clamp(1.4rem, 3vw, 1.75rem);
    margin-bottom: 0.5rem;
    line-height: 1.12;
    letter-spacing: -0.03em;
    max-width: 26ch;
    text-transform: none;
    text-wrap: balance;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-commit-mono), var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    letter-spacing: 0.02em;
  }

  .post-meta time {
    font-variant-numeric: tabular-nums;
  }

  .meta-sep {
    color: var(--cloud);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .tag-link {
    font-size: 0.6rem;
    font-family: var(--font-commit-mono), var(--font-mono);
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--cloud);
    color: var(--muted);
    transition: border-color 0.2s cubic-bezier(0.4, 0, 0.2, 1),
                color 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .tag-link:hover {
    border-color: var(--accent);
    color: var(--fg);
  }

  /* Mobile ToC */
  .mobile-toc {
    margin-bottom: 2rem;
    border: 2px solid var(--fg);
    box-shadow: 4px 4px 0 var(--fg);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--cloud) 24%, transparent), transparent 42%),
      var(--bg);
  }

  .toc-summary {
    padding: 0.85rem 1rem 0.8rem;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--fg);
    cursor: pointer;
    user-select: none;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition: color 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    list-style: none;
  }

  .toc-summary:hover {
    color: var(--fg);
  }

  .toc-summary::marker,
  .toc-summary::-webkit-details-marker {
    display: none;
  }

  .toc-summary::after {
    content: "+";
    float: right;
    font-size: 1rem;
    line-height: 1;
  }

  .mobile-toc[open] .toc-summary::after {
    content: "−";
  }

  .toc-nav {
    padding: 0 1rem 1rem;
    border-top: 1px solid var(--cloud);
  }

  .toc-nav ul {
    list-style: none;
  }

  .toc-nav li {
    margin-bottom: 0.3rem;
  }

  /* Mobile: collapse sub-headings by default; expand on active scroll-spy
     group or when the parent <li> is tapped (via .toc-group.open). */
  .toc-nav .toc-children {
    max-height: 0;
    overflow: hidden;
    margin: 0;
    padding: 0;
    transition: max-height 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .toc-nav .toc-group.expanded > .toc-children,
  .toc-nav .toc-group.open > .toc-children {
    max-height: 40rem;
  }

  .toc-nav a {
    font-family: var(--font-commit-mono), var(--font-mono);
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--fg) 78%, var(--muted));
    padding: 0.3rem 0;
    display: block;
    transition: color 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .toc-nav a:hover {
    color: var(--fg);
  }

  .toc-h3 a {
    padding-left: 1rem;
    font-size: 0.7rem;
  }

  .toc-h4 a {
    padding-left: 2rem;
    font-size: 0.68rem;
    opacity: 0.8;
  }

  /* ── Post content — the reading experience ── */
  .post-content {
    font-family: var(--font-reading);
    font-size: clamp(1rem, 1.34vw, 1.08rem);
    line-height: 1.68;
    color: var(--fg);
    letter-spacing: 0.001em;
    word-spacing: 0.01em;
    max-width: 82ch;
    font-variation-settings: "MONO" 0, "CASL" 0.18, "wght" 435, "slnt" -6;
    font-variant-numeric: oldstyle-nums proportional-nums;
    hanging-punctuation: first allow-end;
  }

  :global(.post-content .series-intro) {
    margin: 0 0 2.8rem;
    padding: 1rem 1.15rem 1.2rem;
    border: 2px solid var(--fg);
    box-shadow: 5px 5px 0 var(--fg);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--cloud) 26%, transparent), transparent 38%),
      var(--bg);
  }

  :global(.post-content .series-kicker) {
    margin: 0 0 0.3rem;
    font-family: var(--font-commit-mono), var(--font-mono);
    font-size: 0.76rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--fg);
  }

  :global(.post-content .series-label) {
    margin: 0 0 0.55rem;
    font-family: var(--font-commit-mono), var(--font-mono);
    font-size: 0.63rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--muted);
  }

  :global(.post-content .series-links) {
    margin: 0 0 1rem;
    padding-left: 1.25rem;
    font-family: var(--font-commit-mono), var(--font-mono);
    font-size: 0.84rem;
    line-height: 1.55;
  }

  :global(.post-content .series-links li) {
    margin-bottom: 0.25rem;
  }

  :global(.post-content .series-links [aria-current="page"]) {
    font-weight: 700;
  }

  :global(.post-content .standfirst) {
    font-size: 1.06em;
    line-height: 1.74;
    max-width: 62ch;
    margin-bottom: 0.9rem;
    font-variation-settings: "MONO" 0, "CASL" 0.22, "wght" 450, "slnt" -7;
  }

  :global(.post-content .standfirst:last-child) {
    margin-bottom: 0;
  }

  /* Widows & orphans — keep paragraphs from leaving lonely lines */
  .post-content p,
  .post-content li,
  .post-content blockquote p {
    orphans: 3;
    widows: 3;
    text-wrap: pretty;
  }

  /* Drop cap on the first paragraph after the header */
  .post-content > p:first-of-type::first-letter,
  :global(.post-content .series-intro + h2 + p)::first-letter {
    font-family: var(--font-commit-mono), var(--font-mono);
    font-size: 3.2em;
    float: left;
    line-height: 0.8;
    padding-right: 0.08em;
    margin-top: 0.05em;
    font-weight: 700;
    color: var(--accent);
  }

  /* Headings — clear hierarchy with generous breathing room */
  :global(.post-content h2) {
    font-family: var(--font-commit-mono), var(--font-mono);
    font-size: clamp(1.18rem, 1.4vw, 1.36rem);
    margin-top: 4rem;
    margin-bottom: 1.35rem;
    scroll-margin-top: calc(var(--nav-total-height, 116px) + 1.5rem);
    padding-top: 1.35rem;
    border-top: 2px solid color-mix(in srgb, var(--fg) 55%, var(--cloud));
    letter-spacing: -0.03em;
    text-transform: none;
    line-height: 1.12;
    position: relative;
  }

  :global(.post-content h2)::before {
    content: "// ";
    color: var(--muted);
    font-weight: 400;
  }

  :global(.post-content h2)::after {
    content: "";
    display: block;
    width: 3.25rem;
    height: 0.22rem;
    margin-top: 0.7rem;
