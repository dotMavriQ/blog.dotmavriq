---
import BaseLayout from "../layouts/BaseLayout.astro";
import CloudMarquee from "../components/CloudMarquee.astro";
import StructuralArt from "../components/StructuralArt.astro";
---

<BaseLayout
  title="social // dotmavriq.life"
  description="Live feed of original posts from social.dotmavriq.life — fediverse home of dotMavriQ.">
  <Fragment slot="head">
    <link rel="preconnect" href="https://social.dotmavriq.life" crossorigin />
    <link rel="dns-prefetch" href="https://social.dotmavriq.life" />
  </Fragment>
  <CloudMarquee slot="marquee" />

  <div class="social-backdrop" aria-hidden="true">
    <StructuralArt />
  </div>

  <section class="social-page">
    <div id="social-feed" class="social-feed">
      <!-- Skeleton placeholders paint instantly (no JS) so the feed has shape
           before the first fetch resolves; cleared by feedEl.innerHTML on load. -->
      <div class="social-feed-skeleton" aria-hidden="true">
        <article class="social-post-skeleton">
          <div class="sk-head">
            <span class="sk sk-avatar"></span>
            <span class="sk-meta"><span class="sk sk-name"></span><span class="sk sk-date"></span></span>
          </div>
          <span class="sk sk-line"></span>
          <span class="sk sk-line"></span>
          <span class="sk sk-line sk-line--short"></span>
          <span class="sk sk-media"></span>
        </article>
        <article class="social-post-skeleton">
          <div class="sk-head">
            <span class="sk sk-avatar"></span>
            <span class="sk-meta"><span class="sk sk-name"></span><span class="sk sk-date"></span></span>
          </div>
          <span class="sk sk-line"></span>
          <span class="sk sk-line sk-line--short"></span>
        </article>
        <article class="social-post-skeleton">
          <div class="sk-head">
            <span class="sk sk-avatar"></span>
            <span class="sk-meta"><span class="sk sk-name"></span><span class="sk sk-date"></span></span>
          </div>
          <span class="sk sk-line"></span>
          <span class="sk sk-line"></span>
          <span class="sk sk-line sk-line--short"></span>
        </article>
      </div>
      <div class="social-loading" role="status" aria-live="polite">
        <span class="social-loading-label">loading</span><span class="social-loading-dots" aria-hidden="true"><span>.</span><span>.</span><span>.</span></span>
      </div>
    </div>
    <div id="social-load-more" class="social-load-more" style="display:none;">
      <button class="social-load-more-btn" id="social-load-more-btn">// load more</button>
    </div>
  </section>

  <div class="social-lightbox" id="social-lightbox" aria-hidden="true">
    <span class="social-lightbox-counter" id="social-lb-counter"></span>
    <button class="social-lightbox-close" id="social-lb-close" aria-label="Close">&times;</button>
    <div class="social-lightbox-stage" id="social-lb-stage">
      <button class="social-lightbox-prev" id="social-lb-prev" aria-label="Previous">
        <span class="social-lightbox-arrow">&larr;</span>
      </button>
      <img id="social-lb-img" src="" alt="" />
      <button class="social-lightbox-next" id="social-lb-next" aria-label="Next">
        <span class="social-lightbox-arrow">&rarr;</span>
        <span class="social-lightbox-next-label" id="social-lb-next-label" aria-hidden="true"></span>
      </button>
    </div>
    <button class="social-lightbox-cw" id="social-lb-cw" type="button">
      <span class="social-lightbox-cw__inner">
        <span class="social-lightbox-cw__title" id="social-lb-cw-title">// sensitive content</span>
        <span class="social-lightbox-cw__hint">click to reveal</span>
      </span>
    </button>
    <div class="social-lightbox-alt" id="social-lb-alt"></div>
    <div class="social-lightbox-skip" id="social-lb-skip"></div>
  </div>

  <aside class="social-tag-panel" id="social-tag-panel" aria-hidden="true" aria-label="Posts tagged">
    <header class="social-tag-panel__head">
      <h2 class="social-tag-panel__title" id="social-tag-title">#</h2>
      <button class="social-tag-panel__close" id="social-tag-close" type="button" aria-label="Close tag results">&times;</button>
    </header>
    <div class="social-tag-panel__body" id="social-tag-list"></div>
  </aside>

  <button class="social-follow-btn" id="social-follow-btn" type="button">⁂ follow</button>

  <div class="social-profile-overlay" id="social-profile-overlay" role="dialog" aria-modal="true" aria-labelledby="social-profile-name">
    <div class="social-profile-card">
      <a class="social-profile-go" id="social-profile-go" href="https://social.dotmavriq.life/users/dotmavriq"
         target="_blank" rel="noopener" aria-label="Open profile on social.dotmavriq.life in a new tab">
        <span aria-hidden="true">[ ↗ ]</span>
      </a>
      <button class="social-profile-close" id="social-profile-close" type="button" aria-label="Close">&times;</button>

      <div class="social-profile-head">
        <img class="social-profile-avatar" id="social-profile-avatar" src="" alt="" />
        <div class="social-profile-ident">
          <div class="social-profile-name" id="social-profile-name">…</div>
          <div class="social-profile-handle" id="social-profile-handle">…</div>
        </div>
      </div>

      <div class="social-profile-bio" id="social-profile-bio"></div>

      <div class="social-profile-fields" id="social-profile-fields"></div>

      <div class="social-profile-stats">
        <div class="social-profile-stat">
          <span class="social-profile-stat__num" id="social-profile-stat-posts">—</span>
          <span class="social-profile-stat__label">posts</span>
        </div>
        <div class="social-profile-stat">
          <span class="social-profile-stat__num" id="social-profile-stat-following">—</span>
          <span class="social-profile-stat__label">following</span>
        </div>
        <div class="social-profile-stat">
          <span class="social-profile-stat__num" id="social-profile-stat-followers">—</span>
          <span class="social-profile-stat__label">followers</span>
        </div>
      </div>

      <div class="social-profile-joined" id="social-profile-joined"></div>
    </div>
  </div>

  <div class="social-follow-overlay" id="social-follow-overlay">
    <div class="social-follow-modal">
      <button class="social-follow-close" id="social-follow-close" aria-label="Close">&times;</button>
      <h2>follow from your instance</h2>
      <p>Enter your fediverse handle and you'll be redirected to your instance to confirm.</p>
      <div class="social-follow-input-row">
        <input class="social-follow-input" id="social-follow-handle" type="text"
          placeholder="user@mastodon.social" autocomplete="off" spellcheck="false" />
        <button class="social-follow-submit" id="social-follow-submit" type="button">go</button>
      </div>
      <div class="social-follow-error" id="social-follow-error"></div>
      <p class="social-follow-rss">
        or if you simply want to lurk, here's the
        <a href="https://social.dotmavriq.life/users/dotmavriq/feed.atom" target="_blank" rel="noopener">atom rss feed</a>
      </p>
    </div>
  </div>

  <!-- QR / "from social media" welcome modal — only triggered by ?from=qr -->
  <div class="social-qr-overlay" id="social-qr-overlay" role="dialog" aria-modal="true" aria-labelledby="social-qr-title-en" aria-hidden="true">
    <div class="social-qr-modal">
      <button class="social-qr-close" id="social-qr-close" type="button" aria-label="Close">&times;</button>

      <div class="social-qr-flags" role="tablist" aria-label="Language">
        <button class="social-qr-flag" data-lang="sv" role="tab" aria-label="Svenska" type="button">🇸🇪</button>
        <button class="social-qr-flag" data-lang="en" role="tab" aria-label="English" type="button">🇬🇧</button>
        <button class="social-qr-flag" data-lang="pt" role="tab" aria-label="Português" type="button">🇵🇹</button>
      </div>

      <div class="social-qr-body">
        <!-- ── Swedish ── -->
        <article class="social-qr-content" data-lang="sv">
          <h2 id="social-qr-title-sv" class="social-qr-h">En QR-kod ledde dig hit.</h2>
          <p>Jag har valt att inte längre använda mina konton på de konventionella sociala medietjänsterna. Några skäl, kort:</p>
          <p>Om du inte betalar för produkten är <strong>du</strong> produkten. Precis som AI idag stod dessa plattformar värd för oss i flera år på en optimism som mest bestod av VC-pengar. Nu måste de leverera siffror — det är den största anledningen till att tjänsterna blir sämre och att vi hela tiden hör om <a href="https://internetkunskap.se/artiklar/integritet/det-har-ar-integritet-och-darfor-behover-du-bry-dig/" target="_blank" rel="noopener">vad de gör med vår data</a>. De samhälleliga konsekvenserna kartläggs fortfarande.</p>
          <p>En sak de gör, som jag vägrar stödja som konsument, är <a href="https://www.deceptive.design/" target="_blank" rel="noopener">dark patterns</a>: gränssnitt medvetet designade för att manipulera snarare än tjäna.</p>
          <p>Här är några höjdpunkter från trovärdiga källor:</p>
          <ul>
            <li><strong>Meta</strong> (Facebook, Instagram, WhatsApp): <a href="https://www.wsj.com/articles/facebook-knows-instagram-is-toxic-for-teen-girls-company-documents-show-11631620739" target="_blank" rel="noopener">Instagrams skada på tonåringars mentala hälsa</a>, <a href="https://www.theguardian.com/technology/2018/mar/17/cambridge-analytica-facebook-influence-us-election" target="_blank" rel="noopener">valpåverkan</a>, <a href="https://www.amnesty.org/en/latest/news/2022/09/myanmar-facebooks-systems-promoted-violence-against-rohingya-meta-owes-reparations-new-report/" target="_blank" rel="noopener">medbrottslighet i Rohingya-folkmordet i Myanmar</a>, <a href="https://www.reuters.com/article/us-vietnam-facebook-exclusive-idUSKBN2270WV" target="_blank" rel="noopener">censur på begäran av auktoritära regimer</a>, och <a href="https://www.theguardian.com/technology/2021/oct/05/facebook-whistleblower-frances-haugen-calls-for-urgent-external-regulation" target="_blank" rel="noopener">nedtonande av sin egen interna forskning om samhällsskador</a>.</li>
            <li><strong>TikTok</strong>: <a href="https://www.amnesty.org/en/latest/news/2023/11/tiktok-risks-pushing-children-towards-harmful-content/" target="_blank" rel="noopener">att styra tonåringar mot självskadeinnehåll inom minuter</a>.</li>
            <li><strong>X</strong>: <a href="https://www.404media.co/taylor-swift-deepfakes-ai-generated-porn/" target="_blank" rel="noopener">att tolera spridningen av AI-genererat övergreppsbildmaterial riktat mot kvinnor</a>, och <a href="https://www.theguardian.com/technology/2023/oct/19/x-twitter-algorithm-favors-republican-elon-musk-study" target="_blank" rel="noopener">att medvetet förstärka högerinriktat innehåll till sina användare</a>.</li>
          </ul>

          <h3 class="social-qr-h3">Så vad är det här då?</h3>
          <p>Jag bor utomlands och vill fortfarande dela mitt liv med de jag känner — och de jag kanske kommer att lära känna online; jag älskar fortfarande att nätverka — utan att lämna över det till en miljardärs algoritm. Jag tror på det fria och öppna internet, så jag finns på <strong>Fediversen</strong>: tusentals oberoende servrar (Mastodon, Pleroma…) som pratar med varandra, som e-post. Ingen enskild ägare, ingen muromgärdad trädgård, inga annonser.</p>
          <p>Enklaste vägen in: <a href="https://joinmastodon.org/sv" target="_blank" rel="noopener">en kort förklaring</a>, gå med på <a href="https://mastodon.nu" target="_blank" rel="noopener">mastodon.nu</a>, tryck sedan på <code>⁂ follow</code> på sidan. Eller skippa kontot — <a href="https://social.dotmavriq.life/users/dotmavriq/feed.atom" target="_blank" rel="noopener">prenumerera via RSS</a>.</p>
        </article>

        <!-- ── English ── -->
        <article class="social-qr-content" data-lang="en">
          <h2 id="social-qr-title-en" class="social-qr-h">A QR got you here.</h2>
          <p>I've chosen to stop using my accounts on the conventional social media services. A few reasons, briefly:</p>
          <p>If you're not paying for the product, <strong>you</strong> are the product. Much like AI today, these platforms hosted us for years on optimism that was mostly VC funding. Now they need to make their numbers — that's the biggest reason the services keep getting worse, and the reason we keep hearing about <a href="https://myshadow.org/tracking-so-what" target="_blank" rel="noopener">what they do with our data</a>. The societal repercussions are still being mapped.</p>
          <p>One thing they do, that I refuse to support as a consumer, is <a href="https://www.deceptive.design/" target="_blank" rel="noopener">dark patterns</a>: interfaces deliberately engineered to manipulate rather than serve.</p>
          <p>Here are some highlights from reputable sources:</p>
          <ul>
            <li><strong>Meta</strong> (Facebook, Instagram, WhatsApp): <a href="https://www.wsj.com/articles/facebook-knows-instagram-is-toxic-for-teen-girls-company-documents-show-11631620739" target="_blank" rel="noopener">Instagram's harm to teenage mental health</a>, <a href="https://www.theguardian.com/technology/2018/mar/17/cambridge-analytica-facebook-influence-us-election" target="_blank" rel="noopener">election interference</a>, <a href="https://www.amnesty.org/en/latest/news/2022/09/myanmar-facebooks-systems-promoted-violence-against-rohingya-meta-owes-reparations-new-report/" target="_blank" rel="noopener">complicity in Myanmar's Rohingya genocide</a>, <a href="https://www.reuters.com/article/us-vietnam-facebook-exclusive-idUSKBN2270WV" target="_blank" rel="noopener">censoring posts at the request of authoritarian regimes</a>, and <a href="https://www.theguardian.com/technology/2021/oct/05/facebook-whistleblower-frances-haugen-calls-for-urgent-external-regulation" target="_blank" rel="noopener">downplaying its own internal research on societal harm</a>.</li>
            <li><strong>TikTok</strong>: <a href="https://www.amnesty.org/en/latest/news/2023/11/tiktok-risks-pushing-children-towards-harmful-content/" target="_blank" rel="noopener">routing teens toward self-harm content within minutes</a>.</li>
            <li><strong>X</strong>: <a href="https://www.404media.co/taylor-swift-deepfakes-ai-generated-porn/" target="_blank" rel="noopener">tolerating the spread of AI-generated abuse imagery targeting women</a>, and <a href="https://www.theguardian.com/technology/2023/oct/19/x-twitter-algorithm-favors-republican-elon-musk-study" target="_blank" rel="noopener">deliberately amplifying right-wing content to its users</a>.</li>
          </ul>

          <h3 class="social-qr-h3">So what is this?</h3>
          <p>I live abroad and still want to share my life with the people I know — and the ones I might come to know online; I still love networking — without handing it over to a billionaire's algorithm. I believe in the free and open internet, so I'm on the <strong>Fediverse</strong>: thousands of independent servers (Mastodon, Pleroma…) that all talk to each other, like email. No single owner, no walled garden, no ads.</p>
          <p>Easiest way in: <a href="https://joinmastodon.org/" target="_blank" rel="noopener">a short explainer</a>, join <a href="https://mastodon.social" target="_blank" rel="noopener">mastodon.social</a>, then hit <code>⁂ follow</code> on this page. Or skip the account — <a href="https://social.dotmavriq.life/users/dotmavriq/feed.atom" target="_blank" rel="noopener">subscribe via RSS</a>.</p>
        </article>

        <!-- ── Portuguese ── -->
        <article class="social-qr-content" data-lang="pt">
          <h2 id="social-qr-title-pt" class="social-qr-h">Um QR trouxe-te aqui.</h2>
          <p>Escolhi deixar de usar as minhas contas nas redes sociais convencionais. Algumas razões, brevemente:</p>
          <p>Se não pagas pelo produto, o produto és <strong>tu</strong>. Tal como a IA hoje, estas plataformas alojaram-nos durante anos com um otimismo que era sobretudo capital de risco. Agora precisam de gerar receita — é a maior razão pela qual os serviços continuam a piorar, e a razão pela qual ouvimos constantemente sobre <a href="https://myshadow.org/pt/tracking-so-what" target="_blank" rel="noopener">o que fazem com os nossos dados</a>. As repercussões sociais ainda estão a ser mapeadas.</p>
          <p>Uma coisa que fazem, e que me recuso a apoiar enquanto consumidor, são os <a href="https://www.deceptive.design/" target="_blank" rel="noopener">dark patterns</a>: interfaces deliberadamente desenhadas para manipular em vez de servir.</p>
          <p>Aqui estão alguns destaques de fontes credíveis:</p>
          <ul>
            <li><strong>Meta</strong> (Facebook, Instagram, WhatsApp): <a href="https://www.wsj.com/articles/facebook-knows-instagram-is-toxic-for-teen-girls-company-documents-show-11631620739" target="_blank" rel="noopener">o dano do Instagram à saúde mental dos adolescentes</a>, <a href="https://www.theguardian.com/technology/2018/mar/17/cambridge-analytica-facebook-influence-us-election" target="_blank" rel="noopener">interferência eleitoral</a>, <a href="https://www.amnesty.org/en/latest/news/2022/09/myanmar-facebooks-systems-promoted-violence-against-rohingya-meta-owes-reparations-new-report/" target="_blank" rel="noopener">cumplicidade no genocídio dos Rohingya em Myanmar</a>, <a href="https://www.reuters.com/article/us-vietnam-facebook-exclusive-idUSKBN2270WV" target="_blank" rel="noopener">censura a pedido de regimes autoritários</a>, e <a href="https://www.theguardian.com/technology/2021/oct/05/facebook-whistleblower-frances-haugen-calls-for-urgent-external-regulation" target="_blank" rel="noopener">minimização da sua própria investigação interna sobre danos sociais</a>.</li>
            <li><strong>TikTok</strong>: <a href="https://www.amnesty.org/en/latest/news/2023/11/tiktok-risks-pushing-children-towards-harmful-content/" target="_blank" rel="noopener">encaminhar adolescentes para conteúdo de auto-mutilação em minutos</a>.</li>
            <li><strong>X</strong>: <a href="https://www.404media.co/taylor-swift-deepfakes-ai-generated-porn/" target="_blank" rel="noopener">tolerar a propagação de imagens abusivas geradas por IA visando mulheres</a>, e <a href="https://www.theguardian.com/technology/2023/oct/19/x-twitter-algorithm-favors-republican-elon-musk-study" target="_blank" rel="noopener">amplificar deliberadamente conteúdo de direita junto dos seus utilizadores</a>.</li>
          </ul>

          <h3 class="social-qr-h3">Então o que é isto?</h3>
          <p>Vivo no estrangeiro e ainda quero partilhar a minha vida com quem conheço — e com quem talvez venha a conhecer online; continuo a adorar fazer networking — sem entregá-la ao algoritmo de um bilionário. Acredito na internet livre e aberta, por isso estou no <strong>Fediverso</strong>: milhares de servidores independentes (Mastodon, Pleroma…) que comunicam entre si, como o email. Sem dono único, sem jardim murado, sem anúncios.</p>
          <p>Caminho mais fácil: <a href="https://joinmastodon.org/pt" target="_blank" rel="noopener">uma breve explicação</a>, adere ao <a href="https://masto.pt" target="_blank" rel="noopener">masto.pt</a>, depois carrega no <code>⁂ follow</code> desta página. Ou ignora a conta — <a href="https://social.dotmavriq.life/users/dotmavriq/feed.atom" target="_blank" rel="noopener">subscreve via RSS</a>.</p>
        </article>
      </div>

      <div class="social-qr-actions">
        <button class="social-qr-confirm" id="social-qr-confirm" type="button">I understand</button>
      </div>
    </div>
  </div>

  <script>
    // QR / "from social media" welcome modal trigger.
    // Only fires when the URL carries ?from=qr. Persists dismissal in
    // localStorage when the user hits the confirm button; the X button
    // closes without persisting (so a refresh shows it again).
    let qrAbort: AbortController | null = null;
    const initQrWelcome = () => {
      const params = new URLSearchParams(window.location.search);
      if (params.get("from") !== "qr") return;

      const overlay = document.getElementById("social-qr-overlay");
      if (!overlay) return;
      // Guard against double-init on the same overlay (e.g. astro:page-load
      // firing alongside the initial-load fallback).
      if (overlay.dataset.qrInit === "1") return;
      overlay.dataset.qrInit = "1";
      const STORAGE_KEY = "social-qr-welcome-seen";
      try {
        if (localStorage.getItem(STORAGE_KEY) === "1") return;
      } catch {}

      qrAbort?.abort();
      qrAbort = new AbortController();
      const { signal } = qrAbort;

      const flags = overlay.querySelectorAll<HTMLButtonElement>(".social-qr-flag");
      const contents = overlay.querySelectorAll<HTMLElement>(".social-qr-content");
      const confirmBtn = document.getElementById("social-qr-confirm") as HTMLButtonElement | null;
      const closeBtn = document.getElementById("social-qr-close") as HTMLButtonElement | null;

      const confirmLabels: Record<string, string> = {
        sv: "Jag förstår",
        en: "I understand",
        pt: "Eu compreendo",
      };

      // Auto-fit body text: shrink font-size until the content stops
      // overflowing, with a legibility floor. Re-runs on language change
      // and on resize.
      const body = overlay.querySelector<HTMLElement>(".social-qr-body");
      const FIT_MAX = 0.92; // rem
      const FIT_MIN = 0.72; // rem
      const FIT_STEP = 0.02;
      const fitContent = () => {
        if (!body) return;
        let size = FIT_MAX;
        body.style.fontSize = `${size}rem`;
        // Allow the browser to apply the size before measuring.
        let guard = 0;
        while (body.scrollHeight > body.clientHeight + 1 && size > FIT_MIN && guard++ < 40) {
          size -= FIT_STEP;
          body.style.fontSize = `${size}rem`;
        }
      };

      const setLang = (lang: string) => {
        contents.forEach((c) => {
          if (c.dataset.lang === lang) {
            c.removeAttribute("hidden");
          } else {
            c.setAttribute("hidden", "");
          }
        });
        flags.forEach((f) => {
          const active = f.dataset.lang === lang;
          f.classList.toggle("is-active", active);
          f.setAttribute("aria-selected", String(active));
        });
        if (confirmBtn) confirmBtn.textContent = confirmLabels[lang] ?? confirmLabels.en;
        overlay.setAttribute("aria-labelledby", `social-qr-title-${lang}`);
        // Run fit after layout settles for the newly-shown article.
        requestAnimationFrame(fitContent);
      };

      // Default to browser language; Swedish/Portuguese match by prefix.
      const nav = (navigator.language || "en").toLowerCase();
      const initial = nav.startsWith("sv") ? "sv" : nav.startsWith("pt") ? "pt" : "en";
      setLang(initial);

      flags.forEach((f) => {
        f.addEventListener("click", () => f.dataset.lang && setLang(f.dataset.lang), { signal });
      });

      // Focus management: remember what was focused so we can restore on
      // close, and trap Tab inside the modal while open. Visible flags are
      // tab-stops too, but the close button is the predictable initial
      // target — it's the universal escape hatch.
      let previouslyFocused: HTMLElement | null = null;
      const FOCUSABLE_SELECTOR = [
        "a[href]",
        "button:not([disabled])",
        "input:not([disabled])",
        "textarea:not([disabled])",
        "select:not([disabled])",
        '[tabindex]:not([tabindex="-1"])',
      ].join(",");
      const getFocusable = (): HTMLElement[] => {
        const nodes = overlay.querySelectorAll<HTMLElement>(FOCUSABLE_SELECTOR);
        return Array.from(nodes).filter((el) => {
          if (el.hasAttribute("hidden")) return false;
          if (el.closest("[hidden]")) return false;
          // offsetParent === null catches display:none ancestors.
          return el.offsetParent !== null || el === document.activeElement;
        });
      };

      const open = () => {
        previouslyFocused = document.activeElement as HTMLElement | null;
        overlay.classList.add("open");
        overlay.setAttribute("aria-hidden", "false");
        document.body.classList.add("has-qr-modal-open");
        // Modal was display:none until now; measure once layout is live.
        requestAnimationFrame(() => {
          fitContent();
          (closeBtn ?? getFocusable()[0])?.focus();
        });
      };
      const close = (persist: boolean) => {
        overlay.classList.remove("open");
        overlay.setAttribute("aria-hidden", "true");
        document.body.classList.remove("has-qr-modal-open");
        if (persist) {
          try { localStorage.setItem(STORAGE_KEY, "1"); } catch {}
        }
        if (previouslyFocused && document.contains(previouslyFocused)) {
          previouslyFocused.focus();
        }
        previouslyFocused = null;
      };

      window.addEventListener("resize", () => requestAnimationFrame(fitContent), { passive: true, signal });
      closeBtn?.addEventListener("click", () => close(false), { signal });
      confirmBtn?.addEventListener("click", () => close(true), { signal });
      overlay.addEventListener("click", (e) => {
        if (e.target === overlay) close(false);
      }, { signal });
      document.addEventListener("keydown", (e) => {
        if (!overlay.classList.contains("open")) return;
        if (e.key === "Escape") {
          close(false);
          return;
        }
        if (e.key === "Tab") {
          const focusable = getFocusable();
          if (focusable.length === 0) {
            e.preventDefault();
            return;
          }
          const first = focusable[0];
          const last = focusable[focusable.length - 1];
          const active = document.activeElement as HTMLElement | null;
          if (e.shiftKey) {
            if (active === first || !overlay.contains(active)) {
              e.preventDefault();
              last.focus();
            }
          } else {
            if (active === last || !overlay.contains(active)) {
              e.preventDefault();
              first.focus();
            }
          }
        }
      }, { signal });

      open();
    };

    // astro:page-load fires on initial load with View Transitions enabled and
    // after every client-side navigation. Without it, fall back to a one-shot
    // ready-state check. The overlay's data-qr-init flag prevents both paths
    // from racing into a double init when both fire.
    // Guard the bootstrap registration itself: this <script> re-executes on
    // every Astro client-side navigation, so without a flag we'd stack a new
    // astro:page-load listener on document on each revisit.
    if (!(window as any).__qrWelcomeBootstrapped) {
      (window as any).__qrWelcomeBootstrapped = true;
      document.addEventListener("astro:page-load", initQrWelcome);
      if (document.readyState !== "loading") {
        initQrWelcome();
      } else {
        document.addEventListener("DOMContentLoaded", initQrWelcome, { once: true });
      }
    }
  </script>

  <script>
    import { initSocialFeed } from "../lib/social-feed";
    document.addEventListener("astro:page-load", initSocialFeed);
    if (document.readyState === "loading") {
