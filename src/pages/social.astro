    .social-follow-modal {
      position: relative;
      background: var(--bg);
      border: 3px solid var(--fg);
      box-shadow: 8px 8px 0 var(--fg);
      padding: 2rem;
      max-width: 420px;
      width: calc(100% - 40px);
