      font-family: inherit;
      padding: 0 0 0 0.75rem;
    }
    .social-tag-panel__close:hover { color: var(--fg); }
    .social-tag-panel__close:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }

    .social-tag-panel__body {
      flex: 1;
      min-height: 0;
      overflow-y: auto;
      scrollbar-gutter: stable;
      padding: 1rem 1.25rem 2.5rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }
    /* Loading + empty states inside the body share copy with the main feed. */
    .social-tag-panel__body :global(.social-loading),
    .social-tag-panel__body :global(.social-empty) {
      color: var(--muted);
      font-size: 0.85rem;
      text-align: center;
      padding: 1rem 0;
