      margin-bottom: 1rem;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    /* These elements are inserted via innerHTML, so the styles need to be
       global — Astro's scope hash isn't applied to dynamically-created
       nodes. */
    :global(.social-profile-field) {
      display: grid;
      grid-template-columns: minmax(6.5rem, 0.4fr) 1fr;
      column-gap: 0.85rem;
      row-gap: 0.1rem;
      font-size: 0.8rem;
      align-items: baseline;
    }
    :global(.social-profile-field__name) {
      color: var(--muted);
