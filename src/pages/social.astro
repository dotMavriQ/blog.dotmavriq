    .social-lightbox-skip {
      position: absolute;
      top: 1.25rem;
      left: 50%;
      transform: translateX(-50%);
      max-width: calc(100vw - 12rem);
      color: rgba(255, 255, 255, 0.45);
      font-family: var(--font-commit-mono), var(--font-mono);
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      text-align: center;
      white-space: nowrap;
