    :global(.social-profile-field__name)::before { content: "» "; }
    :global(.social-profile-field__value) {
      color: var(--fg);
      word-break: break-word;
      overflow-wrap: anywhere;
      min-width: 0;
    }

    /* Blog-body blue-highlighter link styling for any link inside the
       card (bio paragraphs + field values). */
    .social-profile-card :global(a) {
      color: var(--fg);
      text-decoration: none;
      border-bottom: 2px solid var(--link-under);
      padding: 0 0.1em 0.01em;
      margin: 0 -0.05em;
      transition: background-color 0.2s cubic-bezier(0.4, 0, 0.2, 1),
