    .social-profile-go {
      position: absolute;
      top: 0.75rem;
      right: 2.75rem;
      font-family: var(--font-commit-mono), var(--font-mono);
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--muted);
      text-decoration: none;
      letter-spacing: 0.05em;
      transition: color 0.15s;
