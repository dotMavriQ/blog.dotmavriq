    /* ── Profile card ── */
    .social-profile-overlay {
      display: none;
      position: fixed;
      inset: 0;
      z-index: 320;
      background: rgba(0, 0, 0, 0.5);
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
    }
    .social-profile-overlay.open { display: flex; }
    .social-profile-card {
      position: relative;
      background: var(--bg);
      color: var(--fg);
      border: 3px solid var(--fg);
      box-shadow: 8px 8px 0 var(--fg);
      padding: 1.75rem 1.75rem 1.5rem;
      /* Match the feed column width so the card sits at the same scale as
         the posts behind it instead of being squeezed. */
      max-width: 680px;
      width: 100%;
      max-height: calc(100vh - 4rem);
      overflow-y: auto;
      /* Reserve the scrollbar gutter so content never touches the bar. */
      scrollbar-gutter: stable;
      font-family: var(--font-commit-mono), var(--font-mono);

      /* Blog-body link palette, scoped to the card so bio + field links
         get the blue highlighter underline used in /blog. */
      --link-under: rgba(70, 140, 195, 0.6);
      --link-under-hover: rgba(70, 140, 195, 0.95);
      --link-bg-hover: rgba(70, 140, 195, 0.14);
    }
    :global([data-theme="dark"]) .social-profile-card {
      --link-under: rgba(130, 190, 235, 0.65);
      --link-under-hover: rgba(130, 190, 235, 1);
      --link-bg-hover: rgba(130, 190, 235, 0.16);
