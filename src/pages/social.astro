      z-index: 510;
      padding: 0.25rem 0.5rem;
      line-height: 1;
    }
    .social-lightbox-close:hover { color: #fff; }

    .social-lightbox-counter {
      position: absolute;
      top: 1.25rem;
      left: 1.5rem;
      color: rgba(255, 255, 255, 0.5);
