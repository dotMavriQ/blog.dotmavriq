---
import BaseLayout from "../layouts/BaseLayout.astro";
import CloudMarquee from "../components/CloudMarquee.astro";

const siteUrl = "https://blog.dotmavriq.life";
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ProfilePage",
  "mainEntity": {
    "@type": "Person",
    "name": "Jonatan Jansson",
    "alternateName": "dotMavriQ",
    "jobTitle": "Experienced Full-Stack Developer",
    "url": `${siteUrl}/cv`,
    "sameAs": [
      "https://github.com/dotMavriQ",
      "https://www.linkedin.com/in/janssonjonatan/"
    ],
    "worksFor": {
      "@type": "Organization",
      "name": "Nordhealth"
    },
    "knowsAbout": [
      "JavaScript", "TypeScript", "PHP", "Python", "React", "Next.js",
      "Astro", "Laravel", "WordPress", "Node.js", "Docker",
      "GitHub Actions", "CI/CD", "PostgreSQL", "GraphQL", "REST APIs",
      "Playwright", "HubSpot", "SEO", "GEO", "WCAG", "GDPR",
      "Core Web Vitals", "AI workflows"
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Lisbon",
      "addressCountry": "PT"
    },
    "knowsLanguage": ["Swedish", "English", "Portuguese"]
  }
});
---

<BaseLayout
  title="cv // dotmavriq"
  description="CV: Jonatan Jansson, Experienced Full-Stack Developer based in Lisbon. 10+ years, 70+ clients, currently at Nordhealth. JavaScript/TypeScript, React, PHP, Python, CI/CD, AI workflows."
  ogType="profile"
>
  <Fragment slot="head">
    <meta property="profile:first_name" content="Jonatan" />
    <meta property="profile:last_name" content="Jansson" />
    <meta property="profile:username" content="dotMavriQ" />
    <script is:inline type="application/ld+json" set:html={jsonLd} />
  </Fragment>
  <CloudMarquee slot="marquee" />

  <section class="cv">
    <!-- ═══════════════════════════════════════════════
         HEADER — hero-grade intro card
    ═══════════════════════════════════════════════ -->
    <div class="cv-hero">
      <div class="cv-hero-grain" aria-hidden="true"></div>
      <div class="cv-hero-inner">
        <div class="cv-hero-left">
          <span class="cv-label-tag">CURRICULUM VITAE</span>
          <h1>Jonatan Jansson</h1>
          <p class="cv-title">Experienced Full-Stack Developer</p>
        </div>
        <div class="cv-hero-right">
          <p>Lisbon Area, Portugal</p>
          <p>
            <a
              href="#"
              id="cv-email"
              data-m="==QZmlGbuEXayZXYtR3bkBkbhRXYu9ma"
              aria-label="Email me"
            >
              <span class="cv-email-icon" aria-hidden="true">✉</span>
              <span class="cv-email-copy">email me</span>
              <span class="cv-email-print" aria-hidden="true"></span>
            </a>
          </p>
          <p>
            <a
              href="https://www.linkedin.com/in/janssonjonatan/"
              target="_blank"
              rel="noopener">linkedin.com/in/janssonjonatan</a
            >
          </p>
          <p>
            <a
              href="https://github.com/dotMavriQ"
              target="_blank"
              rel="noopener">github.com/dotMavriQ</a
            >
          </p>
          <p><a href="/contact">blog.dotmavriq.life/contact</a></p>
        </div>
      </div>
    </div>

    <!-- ─── Actions bar ─── -->
    <div class="cv-actions">
      <button class="cv-download-btn neu-box neu-pressed" id="cv-print-btn">
        <span class="btn-arrow" aria-hidden="true">&darr;</span> Download PDF
      </button>
      <span class="cv-updated">Updated Apr 2026</span>
      <pre
        class="cv-actions-rule"
        aria-hidden="true">───────────────────────</pre>
      <button class="cv-due-diligence-btn neu-box neu-pressed" id="cv-dd-btn" type="button" aria-expanded="false" aria-controls="cv-dd-modal" onclick="document.getElementById('cv-dd-overlay').toggleAttribute('hidden');this.setAttribute('aria-expanded',String(!document.getElementById('cv-dd-overlay').hasAttribute('hidden')));document.body.style.overflow=document.getElementById('cv-dd-overlay').hasAttribute('hidden')?'':'hidden'">
        <span class="btn-arrow" aria-hidden="true">&rarr;</span> Due Diligence
      </button>
    </div>

    <!-- ─── Due Diligence modal ─── -->
    <div class="cv-dd-overlay" id="cv-dd-overlay" role="dialog" aria-labelledby="cv-dd-title" hidden onclick="if(event.target===this){this.setAttribute('hidden','');document.getElementById('cv-dd-btn').setAttribute('aria-expanded','false');document.body.style.overflow=''}">
      <div class="cv-dd-modal">
        <button class="cv-dd-close" id="cv-dd-close" type="button" aria-label="Close" onclick="document.getElementById('cv-dd-overlay').setAttribute('hidden','');document.getElementById('cv-dd-btn').setAttribute('aria-expanded','false');document.body.style.overflow=''">&times;</button>
        <h2 class="cv-dd-heading" id="cv-dd-title">Due Diligence</h2>
        <p class="cv-dd-standfirst">Supporting evidence, certifications, and verifiable track record.</p>

        <section class="cv-dd-section" id="certifications">
          <h3 class="cv-dd-section-title"><span class="cv-dd-num">01</span> Certifications</h3>
          <div class="cv-dd-grid">
            <!-- TODO: add certifications here -->
            <div class="cv-dd-card">
              <h4>AWS Certified Solutions Architect</h4>
              <p class="cv-dd-card-meta">Amazon Web Services · 2024</p>
              <p>Designing distributed systems on AWS. Verification: <a href="#" target="_blank" rel="noopener">credential link</a></p>
            </div>
            <div class="cv-dd-card">
              <h4>Certified ScrumMaster</h4>
              <p class="cv-dd-card-meta">Scrum Alliance · 2023</p>
              <p>Agile project management and team facilitation.</p>
            </div>
          </div>
        </section>

        <section class="cv-dd-section" id="engagements">
          <h3 class="cv-dd-section-title"><span class="cv-dd-num">02</span> Notable Engagements</h3>
          <div class="cv-dd-grid">
            <!-- TODO: list sites/clients here -->
            <div class="cv-dd-card">
              <h4>Nordhealth Platform</h4>
              <p class="cv-dd-card-meta">11 multi-market web properties · 2022–present</p>
              <p>Unified legacy platforms onto a single stack. CI/CD pipelines, zero-downtime deployments, Core Web Vitals optimisation.</p>
            </div>
            <div class="cv-dd-card">
              <h4>Client Projects (70+)</h4>
              <p class="cv-dd-card-meta">Various · 2014–present</p>
              <p>WordPress, Laravel, React, and e-commerce builds across multiple industries.</p>
            </div>
          </div>
        </section>

        <section class="cv-dd-section" id="languages">
          <h3 class="cv-dd-section-title"><span class="cv-dd-num">03</span> Languages</h3>
          <div class="cv-dd-grid">
            <div class="cv-dd-card">
              <h4>Swedish</h4>
              <p class="cv-dd-card-meta">Native · C2 CEFR</p>
            </div>
            <div class="cv-dd-card">
              <h4>English</h4>
              <p class="cv-dd-card-meta">Fluent · C1 CEFR</p>
            </div>
            <div class="cv-dd-card">
              <h4>Portuguese</h4>
              <p class="cv-dd-card-meta">Conversational · B1 CEFR</p>
            </div>
          </div>
        </section>

        <section class="cv-dd-section" id="references">
          <h3 class="cv-dd-section-title"><span class="cv-dd-num">04</span> References</h3>
          <div class="cv-dd-grid">
            <!-- TODO: add references / testimonials -->
            <div class="cv-dd-card cv-dd-card--quote">
              <blockquote>
                <p>References available upon request. Contact via <a href="mailto:dotmavriq@gmail.com">dotmavriq@gmail.com</a> or <a href="https://www.linkedin.com/in/janssonjonatan/" target="_blank" rel="noopener">LinkedIn</a>.</p>
              </blockquote>
            </div>
          </div>
        </section>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════
         SUMMARY
    ═══════════════════════════════════════════════ -->
    <!-- ═══════════════════════════════════════════════
         SUMMARY — Editorial block
    ═══════════════════════════════════════════════ -->
    <div class="cv-summary">
        <span class="cv-summary-label">// summary</span>
        <p>
          Experienced full-stack developer with <strong>10+ years</strong> in the
          industry and a track record of owning digital products end to end,
          from Linux provisioning through to production deployment. Currently
          sole owner of <strong>11 multi-market web properties</strong> at
          Nordhealth, where I've consolidated legacy platforms onto a unified
          stack, built GitHub&nbsp;Actions CI/CD pipelines for
          zero&#8209;downtime deployments, and shipped
          <strong>AI&#8209;assisted workflows</strong> using Claude and
          MCP&nbsp;servers to auto&#8209;generate and roll out CMS components
          with Playwright&#8209;validated test suites.
        </p>
        <p>
          Before that: <strong>70+ clients</strong> served across
          e&#8209;commerce, public sector, and enterprise. Custom PHP/Node.js
          builds, headless front&#8209;ends in React, Next.js, Vue, and Svelte,
          and a real&#8209;time platform serving thousands of concurrent
          sessions with 25 active stakeholders. I work across
          <strong>JavaScript/TypeScript</strong>, PHP, Python, and SQL, and I've
          led development teams, advised senior leadership on platform strategy,
          and run client&#8209;facing delivery from scoping through invoicing.
        </p>
        <p>
          I specialise in <strong>MarTech and CMS platform engineering</strong>:
          building, owning, and scaling WordPress&#8209;based web properties for
          enterprise clients, with e&#8209;commerce depth across WooCommerce and
          Magento. I care about <strong>performance</strong>,
          <strong>accessibility</strong>, and writing code that the next person
          can actually maintain. Technical skill without communication is
          incomplete. I've always done both.
        </p>
        <p class="cv-summary-coda">
          Based in Lisbon. Open to remote roles in UK/EU core hours.
        </p>
    </div>

    <!-- ═══════════════════════════════════════════════
         SKILLS — tag-pill layout
    ═══════════════════════════════════════════════ -->
    <div class="cv-skills-block neu-box">
      <h2 class="cv-section-label">KEY SKILLS</h2>
      <div class="cv-skills-rows">
        <div class="cv-skill-row">
          <span class="cv-skill-cat">Languages &amp; Tech</span>
          <div class="cv-skill-tags">
            <span class="cv-tag">JavaScript / TypeScript</span>
            <span class="cv-tag">PHP</span>
            <span class="cv-tag">Python</span>
            <span class="cv-tag">SQL</span>
            <span class="cv-tag">Bash</span>
            <span class="cv-tag">HTML5</span>
            <span class="cv-tag">CSS3 / SCSS</span>
          </div>
        </div>
        <div class="cv-skill-row">
          <span class="cv-skill-cat">Frameworks &amp; CMS</span>
          <div class="cv-skill-tags">
            <span class="cv-tag cv-tag-accent">WordPress</span>
            <span class="cv-tag">React</span>
            <span class="cv-tag">Next.js</span>
            <span class="cv-tag">Node.js</span>
            <span class="cv-tag">Laravel</span>
            <span class="cv-tag">Vue</span>
            <span class="cv-tag">WooCommerce</span>
          </div>
        </div>
        <div class="cv-skill-row">
          <span class="cv-skill-cat">Infrastructure &amp; Ops</span>
          <div class="cv-skill-tags">
            <span class="cv-tag">CI/CD</span>
            <span class="cv-tag">GitHub Actions</span>
            <span class="cv-tag">Linux</span>
            <span class="cv-tag">Docker</span>
            <span class="cv-tag">PostgreSQL</span>
            <span class="cv-tag">MySQL</span>
            <span class="cv-tag">REST APIs</span>
            <span class="cv-tag">GraphQL</span>
          </div>
        </div>
        <div class="cv-skill-row">
          <span class="cv-skill-cat">Design &amp; Tools</span>
          <div class="cv-skill-tags">
            <span class="cv-tag">Git</span>
            <span class="cv-tag">Claude AI</span>
            <span class="cv-tag">Playwright</span>
            <span class="cv-tag">Figma</span>
            <span class="cv-tag">Google Analytics (GA4)</span>
            <span class="cv-tag">Google Tag Manager (GTM)</span>
            <span class="cv-tag">HubSpot</span>
            <span class="cv-tag">Jira</span>
          </div>
        </div>
        <div class="cv-skill-row">
          <span class="cv-skill-cat">Practices</span>
          <div class="cv-skill-tags">
            <span class="cv-tag">Agile / Scrum</span>
            <span class="cv-tag">Code Review</span>
            <span class="cv-tag">Performance Optimization</span>
            <span class="cv-tag">A/B Testing</span>
            <span class="cv-tag">Technical Documentation</span>
            <span class="cv-tag">Accessibility</span>
            <span class="cv-tag">WCAG</span>
            <span class="cv-tag">SEO</span>
            <span class="cv-tag">GEO</span>
            <span class="cv-tag">UI/UX</span>
            <span class="cv-tag">Core Web Vitals</span>
            <span class="cv-tag">GDPR</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════════════════
         EXPERIENCE — timeline
    ═══════════════════════════════════════════════ -->
    <h2 class="cv-section-heading neu-border-bottom" id="cv-experience">
      <span class="cv-heading-prefix" aria-hidden="true">//</span> experience
    </h2>

    <div class="cv-timeline">
      <article class="cv-job">
        <div class="cv-timeline-marker" aria-hidden="true">
          <span class="cv-dot cv-dot-active"></span>
          <span class="cv-timeline-line"></span>
        </div>
        <div class="cv-job-body neu-box-sm neu-shadow-sm">
          <div class="cv-job-header">
            <h3>
              <span class="cv-org">Nordhealth</span>
              <span class="cv-role">Full-Stack Developer, Marketing Team</span>
            </h3>
            <span class="cv-dates">2025 &ndash; Present</span>
          </div>
          <ul>
            <li>
              Sole owner of 11 multi-market web properties (WordPress, Eleventy,
              Astro.js) across several business units, responsible for
              architecture, delivery, and uptime.
            </li>
            <li>
              Built AI-assisted deployment pipelines (Claude &amp; MCP servers)
              to auto-generate and roll out CMS components across all
              environments, with Playwright test suites for validation and
              automated reporting to Linear, Slack, and Notion.
            </li>
            <li>
              Migrated and consolidated legacy sites into a unified platform with
              a shared design system using React components and TypeScript.
            </li>
            <li>
              Built and maintain CI/CD pipelines (GitHub Actions) for automated
              testing and zero-downtime deployments, replacing a previously
              fragile manual process.
            </li>
            <li>
              Tune Core Web Vitals, run A/B tests, and optimize caching and
              asset delivery to improve conversion rates.
            </li>
            <li>
              Audit and improve AI search visibility (GEO) across web properties
              and brief marketing teams on emerging AI search strategies.
            </li>
            <li>
              Maintain GDPR compliance, security hardening, Google Analytics
              (GA4), Google Tag Manager (GTM), and HubSpot CRM integrations across all
              properties.
            </li>
            <li>
              Write technical documentation and run hands-on training sessions
              so non-technical teams can self-serve.
            </li>
          </ul>
        </div>
      </article>

      <article class="cv-job">
        <div class="cv-timeline-marker" aria-hidden="true">
          <span class="cv-dot"></span>
          <span class="cv-timeline-line"></span>
        </div>
        <div class="cv-job-body neu-box-sm neu-shadow-sm">
          <div class="cv-job-header">
            <h3>
              <span class="cv-org">Block Labs LTD, Lisbon</span>
              <span class="cv-role">Developer &amp; Team Lead</span>
            </h3>
            <span class="cv-dates">2024 &ndash; 2025</span>
          </div>
          <ul>
            <li>
              Led a development team of three on coinpoker.com, a real-time
              poker platform with thousands of concurrent sessions and 25 active
              stakeholders.
            </li>
            <li>
              Consulted with senior leadership on CMS strategy and platform
              direction, advising on performance, scalability, and technology
              choices.
            </li>
            <li>
              Worked directly with the Product Manager on sprint planning,
              backlog refinement, and release coordination. Maintained technical
              documentation in Confluence.
            </li>
            <li>
              Built custom themes and plugins, designed system architecture, and
              managed advanced CMS configurations.
            </li>
            <li>
              Streamlined the design-to-deploy workflow from Figma handoff
              through to production, reducing turnaround on feature delivery.
            </li>
            <li>
              Handled database and server integrations for enterprise clients.
              Ran performance testing, troubleshooting, and continuous
              optimization.
            </li>
            <li>Led enterprise server migrations and platform hardening.</li>
          </ul>
        </div>
      </article>

      <article class="cv-job">
        <div class="cv-timeline-marker" aria-hidden="true">
          <span class="cv-dot"></span>
          <span class="cv-timeline-line"></span>
        </div>
        <div class="cv-job-body neu-box-sm neu-shadow-sm">
          <div class="cv-job-header">
            <h3>
              <span class="cv-org">IPTOR (GENII Software Group), Lisbon</span>
              <span class="cv-role">Senior Developer</span>
            </h3>
            <span class="cv-dates">2023 &ndash; 2024</span>
          </div>
          <ul>
            <li>
              Owned 20+ web properties across GENII subsidiaries (Iptor, GUS,
              Dorner, Nexiga, fimox, and others), handling maintenance, updates,
              security, and feature development.
            </li>
            <li>
              Built a multi-tenant WordPress plugin integrating the TeamTailor
              API to dynamically generate job listings across organizationally
              distinct entities with separate recruitment workflows under the
              GENII umbrella.
            </li>
            <li>
              Implemented HubSpot SSO integration and expanded MarTech
              capabilities supporting inbound marketing.
            </li>
            <li>
              Handled site migrations between environments, including database
              transfers and media/file restructuring.
            </li>
            <li>
              Conducted a GDPR and cookie compliance audit across the full
              portfolio of domains.
            </li>
          </ul>
        </div>
      </article>

      <article class="cv-job">
        <div class="cv-timeline-marker" aria-hidden="true">
          <span class="cv-dot"></span>
          <span class="cv-timeline-line"></span>
        </div>
        <div class="cv-job-body neu-box-sm neu-shadow-sm">
          <div class="cv-job-header">
            <h3>
              <span class="cv-org">Duva (Carrier Pigeon), Lidk&ouml;ping</span>
              <span class="cv-role">Web Developer</span>
            </h3>
            <span class="cv-dates">2018 &ndash; 2023</span>
          </div>
          <ul>
            <li>
              Owned the full project lifecycle end to end (scoping,
              development, code review, testing, deployment, and invoicing)
              across 50+ clients at the leading web consultancy in
              Lidk&ouml;ping.
            </li>
            <li>
              Progressed from frontend CMS work to full-stack PHP development,
              with production work in React, Vue, Next.js, Svelte, Ember.js, and
              Node.js, including headless front-end builds consuming
              GraphQL and REST APIs.
            </li>
            <li>
              Built and maintained e-commerce storefronts with custom modules,
              payment gateway integrations, and platform upgrades for multiple
              clients.
            </li>
            <li>
              Built a Python middleware service aggregating geospatial data
              across multiple third-party APIs for a map-point integration.
            </li>
            <li>
              Delivered SEO and performance optimization for enterprise clients
              including Academedia, Sweden's largest private education company.
            </li>
            <li>
              Managed Linux hosting environments, CMS security and hardening,
              GDPR compliance, accessibility (WCAG), and payment/e-commerce
              integrations.
            </li>
          </ul>
          <p class="cv-key-clients">
            <strong>Key clients:</strong> Academedia, Helsingborg / Ulricehamn /
            Tranemo / Lidk&ouml;ping municipalities, Assemblin, Absolent Group,
            Viacon, McKonsult, Monokel, Uhip, WisbyTankers, TruckTrust.
          </p>
        </div>
      </article>
    </div>

    <!-- ═══════════════════════════════════════════════
         ADDITIONAL EXPERIENCE
    ═══════════════════════════════════════════════ -->
    <h2 class="cv-section-heading neu-border-bottom">
      <span class="cv-heading-prefix" aria-hidden="true">//</span> additional experience
    </h2>

    <div class="cv-additional-grid">
      <article class="cv-additional-card neu-box-sm neu-shadow-sm">
        <div class="cv-job-header">
          <h3>
            <span class="cv-org">Lidk&ouml;ping Makerspace</span>
            <span class="cv-role">Founder</span>
          </h3>
          <span class="cv-dates">2017 &ndash; 2019</span>
        </div>
        <ul>
          <li>
            Founded and ran a community technology space from scratch:
            negotiated premises, sourced equipment, and built partnerships with
            local government bodies, NGOs, and national think tanks.
          </li>
          <li>
            Grew the NGO chapter to 20+ members and led a team of eight
            co-organizers. Built the web presence for the national Makerspace
            network.
          </li>
        </ul>
      </article>

      <article class="cv-additional-card neu-box-sm neu-shadow-sm">
        <div class="cv-job-header">
          <h3>
            <span class="cv-org">Ember, Lidk&ouml;ping</span>
            <span class="cv-role">IT Support &amp; Systems</span>
          </h3>
          <span class="cv-dates">2017</span>
        </div>
        <ul>
          <li>
            Inbound support, malware remediation, and security hardening for
            local client systems.
          </li>
          <li>
            Remote desktop administration for 50+ client environments.
            PowerShell automation for commercial vehicle data auditing.
          </li>
        </ul>
      </article>

      <article class="cv-additional-card neu-box-sm neu-shadow-sm">
        <div class="cv-job-header">
          <h3>
            <span class="cv-org">Nordic Goods AB</span>
            <span class="cv-role">Developer / SysAdmin</span>
          </h3>
          <span class="cv-dates">2016</span>
        </div>
        <ul>
          <li>
            Owned the full technical stack. Provisioned Ubuntu servers,
            configured nginx, built Magento and WordPress/WooCommerce
            storefronts from scratch.
          </li>
          <li>
            Drove initial marketing campaigns and brought in the company's first
            paying customers.
          </li>
        </ul>
      </article>
    </div>

    <!-- ═══════════════════════════════════════════════
         EDUCATION
    ═══════════════════════════════════════════════ -->
    <h2 class="cv-section-heading neu-border-bottom">
      <span class="cv-heading-prefix" aria-hidden="true">//</span> education
    </h2>

    <div class="cv-edu-grid">
      <article class="cv-edu-card neu-box-sm neu-shadow-sm">
        <div class="cv-edu-year" aria-hidden="true">2015</div>
        <div class="cv-edu-body">
          <h3>
            <span class="cv-org">Lexicon, Sk&ouml;vde</span>
            <span class="cv-role">Certificate of Achievement</span>
          </h3>
          <p>
            Web Application Development with C# (.NET / Visual Studio): ASP.NET,
            database management, MVC architecture, testing practices.
          </p>
        </div>
      </article>

      <article class="cv-edu-card neu-box-sm neu-shadow-sm">
        <div class="cv-edu-year" aria-hidden="true">2008</div>
        <div class="cv-edu-body">
          <h3>
            <span class="cv-org">De La Gardie, Lidk&ouml;ping</span>
            <span class="cv-role">Technical Program (IT)</span>
          </h3>
          <p>
            Web design and development, database management, Active Directory,
            CAD, and applied programming.
          </p>
        </div>
      </article>
    </div>

    <!-- ═══════════════════════════════════════════════
         FOOTER — languages + references
    ═══════════════════════════════════════════════ -->
    <h2 class="cv-section-heading neu-border-bottom">
      <span class="cv-heading-prefix" aria-hidden="true">//</span> languages &amp; references
    </h2>

    <div class="cv-footer-strip neu-box-sm">
      <div class="cv-footer-col">
