---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import DotBlogAI from "../components/DotBlogAI.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const siteUrl = "https://blog.dotmavriq.life";
function canonicalFromPath(pathname: string): string {
  const cleanPath = pathname
    .replace(/\/index\.html$/, "/")
    .replace(/\.html$/, "/")
    .replace(/\/$/, "");
  return new URL(cleanPath || "/", siteUrl).href;
}

const {
  title = "blog.dotmavriq.life",
  description = "Personal blog and portfolio site for dotmavriq.",
  ogImage = `${siteUrl}/cool.webp`,
  ogType = "website",
  canonicalUrl = canonicalFromPath(Astro.url.pathname),
} = Astro.props;

const csp = [
  "default-src 'self'",
  "base-uri 'self'",
  "object-src 'none'",
  "font-src 'self'",
  "img-src 'self' data: https://social.dotmavriq.life https://dotmedia.b-cdn.net",
  "connect-src 'self' https://dotblogai.dotmavriq-6d3.workers.dev https://social.dotmavriq.life",
  "frame-src https://cal.com https://app.cal.com",
  "script-src 'self' 'unsafe-inline' https://app.cal.com",
  "style-src 'self' 'unsafe-inline'",
  "form-action 'self'",
  "manifest-src 'self'",
].join("; ");
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="content-security-policy" content={csp} />

    <Font cssVariable="--font-jgs" preload />
    <Font cssVariable="--font-commit-mono" preload={[{ weight: "400", style: "normal" }]} />
    <Font cssVariable="--font-recursive" />

    <!-- Theme toggle: blocking script to prevent FOUC.
         Inline (cannot import) — storage key must match src/scripts/theme.ts THEME_STORAGE_KEY. -->
    <script is:inline>
      (function() {
        function applyTheme() {
          var saved = localStorage.getItem('blog-theme');
          if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <!-- Favicon stack -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/icon-192.png" sizes="192x192" />
    <link rel="icon" type="image/png" href="/icon-512.png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#f5f3ec" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="blog.dotmavriq.life" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- GEO -->
    <meta name="geo.region" content="PT" />
    <meta name="geo.placename" content="Lisbon" />
    <meta name="language" content="en" />

    <ClientRouter />

    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <nav class="nav" aria-label="Site navigation" transition:animate="none">
      <div class="nav-bar container">
        <a class="nav-logo" href="/"
          ><span class="slash">//</span> blog.dotmavriq.life</a
        >
        <div class="nav-right">
          <ul class="nav-links" id="nav-links" role="list">
            <li><a href="/cv">cv</a></li>
            <li><a href="/portfolio">portfolio</a></li>
            <li><a href="/about">about</a></li>
            <li><a href="/blog">blog</a></li>
            <li><a href="/contact">contact</a></li>
          </ul>
          <button
            class="theme-toggle"
            id="theme-toggle"
            aria-label="Toggle colour theme"
          >
            <span class="icon-sun" aria-hidden="true">☼</span>
            <span class="icon-moon" aria-hidden="true">☽</span>
          </button>
          <button
            class="nav-toggle"
            aria-expanded="false"
            aria-controls="mobile-menu"
            id="nav-toggle"
            aria-label="Toggle menu"
          >
            ☰
          </button>
        </div>
      </div>

      <!-- Kinetic Cloud Border -->
      <slot name="marquee" />
    </nav>

    <!-- Mobile menu overlay — sibling of nav and page-scroll, no stacking context issues -->
    <div id="mobile-menu" class="mobile-menu" role="dialog" aria-label="Navigation" hidden>
      <ul class="mobile-menu__links" role="list">
        <li><a href="/cv">cv</a></li>
        <li><a href="/portfolio">portfolio</a></li>
        <li><a href="/about">about</a></li>
        <li><a href="/blog">blog</a></li>
        <li><a href="/contact">contact</a></li>
      </ul>
    </div>

    <div class="page-scroll" id="page-scroll" transition:animate="none">
      <main class="page-content container" id="main">
        <slot />
      </main>

      <footer class="footer container" transition:animate="none">
        <pre
          class="ascii-divider" aria-hidden="true">|:::|=======|:::|_______|:::|=======|:::|_______|:::|</pre>
        <p>
          &copy; {new Date().getFullYear()} dotmavriq. <span class="slash"
            >//</span
          > crafted with intent.
        </p>
      </footer>
    </div>

    <DotBlogAI />

    <script>
      import { toggleTheme } from "../scripts/theme";

      let ac: AbortController | null = null;

      const init = () => {
        // Tear down previous listeners to avoid stacking on SPA nav
        ac?.abort();
        ac = new AbortController();
        const { signal } = ac;

        // ── Theme toggle ──
        const themeToggle = document.getElementById("theme-toggle");
        if (themeToggle) {
          themeToggle.addEventListener("click", () => toggleTheme(), { signal });
        }

        // ── Nav Toggle ──
        const navToggle = document.getElementById("nav-toggle");
        const mobileMenu = document.getElementById("mobile-menu");

        if (navToggle && mobileMenu) {
          navToggle.addEventListener("click", () => {
            const open = mobileMenu.toggleAttribute("hidden");
            navToggle.setAttribute("aria-expanded", String(!open));
          }, { signal });

          // Close on link click
          mobileMenu.querySelectorAll("a").forEach(link => {
            link.addEventListener("click", () => {
              mobileMenu.toggleAttribute("hidden", true);
              navToggle.setAttribute("aria-expanded", "false");
            }, { signal });
          });

          // Close on Escape
          document.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !mobileMenu.hasAttribute("hidden")) {
              mobileMenu.toggleAttribute("hidden", true);
              navToggle.setAttribute("aria-expanded", "false");
            }
          }, { signal });
        }

        // ── Measure nav height for hero viewport fill ──
        const navEl = document.querySelector(".nav") as HTMLElement;
        if (navEl) {
          const setNavHeight = () => {
            document.documentElement.style.setProperty(
              "--nav-total-height",
              navEl.offsetHeight + "px"
            );
          };
          setNavHeight();
          new ResizeObserver(setNavHeight).observe(navEl);
        }
      };

      document.addEventListener("astro:page-load", init);
      // Fallback for environments where astro:page-load may not fire
      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", init, { once: true });
      } else {
        init();
      }
    </script>

    <style>
      :root {
        --nav-total-height: 110px; /* Fallback for CLS reduction */
      }

      .nav {
        width: 100%;
        background: var(--bg);
        transition: background 0.3s;
        z-index: 100;
        border-bottom: 1px solid var(--cloud);
      }
      .nav-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 20px;
        gap: 1rem;
        max-width: 1200px;
      }
      .nav-logo {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        flex-shrink: 0;
      }
      .nav-logo .slash {
        color: var(--muted);
        font-weight: 400;
      }
      .nav-right {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .nav-links {
        display: flex;
        gap: 1.25rem;
        list-style: none;
      }
      .nav-links a {
        color: var(--muted);
        font-size: 0.85rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }
      .nav-links a:hover {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 4px;
      }

      .theme-toggle {
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        padding: 0;
        font-size: 1.1rem;
        transition: color 0.1s;
        width: 1.5rem;
        height: 1.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        line-height: 1;
      }
      .theme-toggle:hover {
        color: var(--accent);
      }

      /* .icon-sun / .icon-moon visibility lives in global.css (shared with OLIV) */

      .nav-toggle {
        display: none;
        background: none;
        border: none;
        color: var(--muted);
        cursor: pointer;
        font-size: 1.2rem;
      }

      .footer {
        padding: 2rem 0 4rem;
        text-align: center;
        font-size: 0.8rem;
        color: var(--muted);
      }

      @media (max-width: 600px) {
        .nav-toggle {
          display: block;
          position: relative;
          z-index: 10002;
        }

        .nav-links {
          display: none;
        }

        .nav {
          position: relative;
          z-index: 10001;
        }
      }

      /* Mobile menu overlay — sibling of nav/page-scroll, no stacking context issues */
      .mobile-menu {
        display: none;
      }
      .mobile-menu:not([hidden]) {
        display: flex;
        position: fixed;
        inset: 0;
        z-index: 10000;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2rem;
        background: #f5f3ec;
        margin: 0;
      }
      :global([data-theme="dark"]) .mobile-menu:not([hidden]) {
        background: #1a1a17;
      }
      .mobile-menu__links {
        list-style: none;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
        padding: 0;
        margin: 0;
      }
      .mobile-menu__links a {
        color: var(--muted);
        font-size: 1.2rem;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        text-decoration: none;
      }
      .mobile-menu__links a:hover {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 4px;
      }
    </style>
  </body>
</html>
