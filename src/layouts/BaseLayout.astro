---
import "../styles/global.css";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import DotBlogAI from "../components/DotBlogAI.astro";
import Nav from "../components/Nav.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
}

const siteUrl = "https://blog.dotmavriq.life";
function canonicalFromPath(pathname: string): string {
  const cleanPath = pathname
    .replace(/\/index\.html$/, "/")
    .replace(/\.html$/, "/")
    .replace(/\/$/, "");
  return new URL(cleanPath || "/", siteUrl).href;
}

const {
  title = "blog.dotmavriq.life",
  description = "Personal blog and portfolio site for dotmavriq.",
  ogImage = `${siteUrl}/cool.webp`,
  ogType = "website",
  canonicalUrl = canonicalFromPath(Astro.url.pathname),
} = Astro.props;

const csp = [
  "default-src 'self'",
  "base-uri 'self'",
  "object-src 'none'",
  "font-src 'self'",
  "img-src 'self' data: https://social.dotmavriq.life https://dotmedia.b-cdn.net",
  "connect-src 'self' https://dotblogai.dotmavriq-6d3.workers.dev https://social.dotmavriq.life",
  "frame-src https://cal.com https://app.cal.com",
  "script-src 'self' 'unsafe-inline' https://app.cal.com",
  "style-src 'self' 'unsafe-inline'",
  "form-action 'self'",
  "manifest-src 'self'",
].join("; ");
---

<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="content-security-policy" content={csp} />

    <Font cssVariable="--font-jgs" preload />
    <Font cssVariable="--font-commit-mono" preload={[{ weight: "400", style: "normal" }]} />
    <Font cssVariable="--font-recursive" />

    <!-- Theme toggle: blocking script to prevent FOUC.
         Inline (cannot import) — storage key must match src/scripts/theme.ts THEME_STORAGE_KEY. -->
    <script is:inline>
      (function() {
        function applyTheme() {
          var saved = localStorage.getItem('blog-theme');
          if (saved === 'dark' || (!saved && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.setAttribute('data-theme', 'dark');
          } else {
            document.documentElement.setAttribute('data-theme', 'light');
          }
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <!-- Favicon stack -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/icon-192.png" sizes="192x192" />
    <link rel="icon" type="image/png" href="/icon-512.png" sizes="512x512" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#f5f3ec" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="blog.dotmavriq.life" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- GEO -->
    <meta name="geo.region" content="PT" />
    <meta name="geo.placename" content="Lisbon" />
    <meta name="language" content="en" />

    <ClientRouter />

    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav>
      <slot name="marquee" slot="marquee" />
    </Nav>

    <div class="page-scroll" id="page-scroll" transition:animate="none">
      <main class="page-content container" id="main">
        <slot />
      </main>

      <footer class="footer container" transition:animate="none">
        <pre
          class="ascii-divider" aria-hidden="true">|:::|=======|:::|_______|:::|=======|:::|_______|:::|</pre>
        <p>
          &copy; {new Date().getFullYear()} dotmavriq. <span class="slash"
            >//</span
          > crafted with intent.
        </p>
      </footer>
    </div>

    <DotBlogAI />

    <style>
      .footer {
        padding: 2rem 0 4rem;
        text-align: center;
        font-size: 0.8rem;
        color: var(--muted);
      }
    </style>
  </body>
</html>
