# Blog post sources are owned by the user and not shipped during the 2026
# curation window. Directory stays tracked via .gitkeep; the markdown bodies
# are deliberately private until they are rewritten.
src/content/blog/*.md
src/content/blog/*.mdx
!src/content/blog/.gitkeep
