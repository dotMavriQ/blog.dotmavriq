{
  "name": "blog.dotmavriq.life",
  "version": "0.1.5",
  "description": "blog.dotmavriq.life — ASCII-Core DevBlog",
  "type": "module",
  "scripts": {
    "sync-posts": "node scripts/sync-posts.mjs",
    "dev": "npm run sync-posts && astro dev",
    "start": "npm run sync-posts && astro dev",
    "build": "npm run sync-posts && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "guard:remotes": "node scripts/assert-no-local-remotes.mjs",
    "guard:links": "node scripts/assert-no-trailing-slash-links.mjs",
    "guard:builtlinks": "node scripts/assert-no-broken-links.mjs",
    "guard:structure": "node scripts/assert-structural-invariants.mjs",
    "guard:bundle": "node scripts/assert-bundle-budget.mjs",
    "guard:deps": "knip",
    "verify:local": "npm run guard:remotes && npm run guard:links && npm run guard:structure && npm run guard:deps && npx astro check && npm run build && npm run guard:builtlinks && npm run guard:bundle",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "archive": "node scripts/archive-links.mjs",
    "archive:check": "node scripts/archive-links.mjs --check",
    "archive:dry": "node scripts/archive-links.mjs --dry-run",
    "text:audit": "node scripts/text-audit.mjs",
    "text:audit:ai": "node scripts/text-audit.mjs src/content/blog/ai-a-retrospective.md src/content/blog/ai-a-retrospective-part-2.md src/content/blog/ai-a-retrospective-part-3.md"
  },
  "keywords": [],
  "author": "dotmavriq",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@chenglou/pretext": "^0.0.8",
    "@fontsource-variable/recursive": "^5.2.8",
    "astro": "^7.0.3",
    "textlens": "^1.0.11",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "knip": "^6.18.0",
    "playwright": "^1.61.0",
    "sharp": "^0.35.2",
    "unist-util-visit": "^5.1.0"
  },
  "overrides": {
    "vite": "^8"
  }
}
